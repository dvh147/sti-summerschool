# Copy to .env.local (for dev) or set in GitHub Actions (for deploy).
# When a custom domain is purchased, set SITE_URL to it and leave BASE_PATH empty.
SITE_URL=https://dvh147.github.io
BASE_PATH=/sti26

# Cloudflare Worker URL that handles registration submissions and the
# admin dashboard. Deploy the worker (see worker/README.md) and paste its
# URL here.
# Example: https://sti26-registration.<your-cf-account>.workers.dev
PUBLIC_REGISTRATION_API=https://your-worker.example.workers.dev

# Cloudflare Turnstile public site key for the registration form.
# Generate at https://dash.cloudflare.com → Turnstile → Add site.
PUBLIC_TURNSTILE_SITE_KEY=
