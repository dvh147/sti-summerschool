---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, withBase } from "../site";

const shape = [
  {
    date: "Monday, 7 September 2026",
    detail: "Kick-off at noon. Afternoon sessions and workshops for early-career scholars, including guest sessions from Google and the European Patent Office.",
  },
  {
    date: "Tuesday, 8 September 2026",
    detail: "A full day of sessions and keynote lectures, followed by a social gathering and dinner on the beach.",
  },
  {
    date: "Wednesday, 9 September 2026",
    detail: "Morning sessions, closing remarks, and end of the summer school at noon.",
  },
];
---

<BaseLayout title="Program">
  <section class="section">
    <div class="container-narrow prose">
      <p class="eyebrow">Program</p>
      <h1>Program</h1>
      <p class="lede">
        The three-day shape of the school is set; the detailed schedule with
        session titles, speakers, and timings will be announced after the
        paper-acceptance deadline.
      </p>

      <div class="callout">
        <p style="margin-top:0;"><strong>Detailed program: to be announced.</strong></p>
        <p style="margin-bottom:0;">
          We'll publish the full schedule shortly after
          <strong>{site.deadlines.notification.label}</strong>, the notification
          deadline for accepted papers. Submit your work via the
          <a href={withBase("/call-for-papers")}>call for papers</a> by
          {site.deadlines.submission.label}.
        </p>
      </div>

      <h2>Three-day overview</h2>
      <ul class="shape">
        {
          shape.map((d) => (
            <li>
              <div class="shape-date">{d.date}</div>
              <div class="shape-detail">{d.detail}</div>
            </li>
          ))
        }
      </ul>

      <p>
        Keynote lectures by <a href={withBase("/speakers")}>Ashish Arora, Joshua Krieger, and Dashun Wang</a>,
        alongside an interactive panel on AI and Innovation in Europe with
        Ludovic Dibiaggio (SKEMA) and Reinhilde Veugelers (KU Leuven).
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .shape {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .shape li {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-sm);
  }
  .shape-date {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-primary-700);
    margin-bottom: 0.2rem;
  }
  .shape-detail {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
</style>
