---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, withBase } from "../site";

const shape = [
  {
    date: "Monday, 7 September 2026",
    detail: "Kick-off at noon. Afternoon practitioner sessions with guest speakers from Google and the European Patent Office.",
  },
  {
    date: "Tuesday, 8 September 2026",
    detail: "A full day of contributed sessions and keynote lectures, followed by a social gathering and dinner on the beach.",
  },
  {
    date: "Wednesday, 9 September 2026",
    detail: "Morning sessions, the panel discussion on AI and innovation in Europe, closing remarks, and end of the summer school at noon.",
  },
];

const keynotes = [
  { name: "Ashish Arora", affiliation: "Duke" },
  { name: "Joshua Krieger", affiliation: "Harvard" },
  { name: "Dashun Wang", affiliation: "Northwestern" },
];
---

<BaseLayout title="Program">
  <section class="section">
    <div class="container-narrow prose">
      <p class="eyebrow">Program</p>
      <h1>Program</h1>
      <p class="lede">
        The shape of the school and its main building blocks are set. The full schedule with
        session titles, contributed papers, and timings will be published after the
        paper-acceptance deadline.
      </p>

      <div class="callout">
        <p style="margin-top:0;"><strong>Detailed schedule: to be announced.</strong></p>
        <p style="margin-bottom:0;">
          We'll publish the full timetable shortly after
          <strong>{site.deadlines.notification.label}</strong>, the notification
          deadline for accepted papers. Submit your work via the
          <a href={withBase("/call-for-papers")}>call for papers</a> by
          {site.deadlines.submission.label}.
        </p>
      </div>

      <h2>Three-day overview</h2>
      <ul class="shape">
        {
          shape.map((d) => (
            <li>
              <div class="shape-date">{d.date}</div>
              <div class="shape-detail">{d.detail}</div>
            </li>
          ))
        }
      </ul>

      <h2>Keynote lectures</h2>
      <p>
        Three confirmed keynote lectures from leading scholars in the economics and
        science of innovation.
      </p>
      <ul class="block-list">
        {
          keynotes.map((k) => (
            <li>
              <strong>{k.name}</strong>
              <span>{k.affiliation}</span>
            </li>
          ))
        }
      </ul>
      <p>
        <a href={withBase("/speakers")}>More about the keynote speakers →</a>
      </p>

      <h2>Practitioner sessions</h2>
      <p>
        The first afternoon features practitioner sessions with guest speakers from
        <strong> Google</strong> and the <strong>European Patent Office</strong>.
        They will introduce new initiatives, tools, and data resources that matter
        for academic research on science and innovation.
      </p>

      <h2>Panel discussion: AI as leverage for science and innovation in Europe</h2>
      <p>
        An interactive panel where AI entrepreneurs and policymakers debate whether — and
        how — Europe can harness AI to advance science and innovation. Moderated by
        Ludovic Dibiaggio (SKEMA) and Reinhilde Veugelers (KU Leuven), with regional
        and EU policymakers and AI entrepreneurs.
      </p>

      <h2>Contributed sessions</h2>
      <p>
        Contributed work from participants is presented in two formats. There are
        <strong>no parallel tracks</strong> — everyone sees everything.
      </p>
      <ul class="block-list">
        <li>
          <strong>Short presentations (5 min)</strong>
          <span>followed by a poster session for in-depth discussion.</span>
        </li>
        <li>
          <strong>Long presentations (15 min)</strong>
          <span>followed by plenary discussion.</span>
        </li>
      </ul>
      <p>
        The selection of contributions runs through the
        <a href={withBase("/call-for-papers")}>call for papers</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .shape {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .shape li {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-sm);
  }
  .shape-date {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-primary-700);
    margin-bottom: 0.2rem;
  }
  .shape-detail {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .block-list {
    list-style: none;
    margin: 1rem 0 1.5rem;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .block-list li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    padding: 0.6rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
  }
  .block-list span {
    color: var(--color-muted);
  }
</style>
