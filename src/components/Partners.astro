---
import { site, withBase } from "../site";
---

<section class="partners section">
  <div class="container">
    <p class="eyebrow eyebrow-lg">In collaboration with</p>
    <h2>Partners</h2>
    <ul class="partner-list" role="list">
      {
        site.partners.map((p) => (
          <li class="partner">
            {p.logo ? (
              <img src={withBase(p.logo)} alt={`${p.name} logo`} loading="lazy" />
            ) : (
              <span>{p.name}</span>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .partner-list {
    list-style: none;
    margin: 1.5rem 0 0.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    align-items: center;
  }
  .partner {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 1.25rem 1rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 110px;
  }
  .partner img {
    max-height: 70px;
    max-width: 100%;
    width: auto;
    object-fit: contain;
  }
  .partner span {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-primary-700);
    text-align: center;
  }
</style>
